# ==============================================================================
# Enterprise AI Research Assistant - Environment Variables
# ==============================================================================

# Application general configurations
ENVIRONMENT=development  # production, development, testing
APP_NAME="Enterprise AI Research Assistant"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# PostgreSQL Settings
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=research_assistant

# Redis Settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# RabbitMQ Settings
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Celery Settings
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Qdrant Vector DB Settings
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# MLflow Settings
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=research_assistant_evaluation

# Authentication Security Settings
# Generate a secure key in production with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_THIS_IN_PRODUCTION_SECRET_KEY_1234567890
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Model configurations
# Add your API keys here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# Embeddings, Reranker & Base Model paths
MODEL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MODEL_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
MODEL_LLM_MODEL=gpt-4o-mini
MODEL_BASE_MODEL_PATH=Qwen/Qwen2.5-3B-Instruct

# Frontend settings
NEXT_PUBLIC_API_URL=http://localhost:8000
